---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';

// When a client gallery/store goes live (e.g. Pixieset), set this URL and the
// page instantly forwards visitors there. The printed/saved QR code always
// points at /gallery, so it never has to change.
const galleryUrl = 'https://lonehandmedia.pixieset.com/lhm/';

const { email, phone, phoneHref } = site.contact;
const instagram = site.social.find((s) => s.platform === 'Instagram');
---

<Layout
  title="Photo Galleries — Lone Hand Media"
  description="Event and client photo galleries from Lone Hand Media. Scan, browse and order your photos."
>
  {galleryUrl && <meta http-equiv="refresh" content={`0;url=${galleryUrl}`} />}
  {galleryUrl && <script is:inline define:vars={{ galleryUrl }}>window.location.replace(galleryUrl);</script>}
  <Nav />
  <main>
    <section class="felt relative flex min-h-[100svh] items-center overflow-hidden pt-28 pb-16">
      <div class="pointer-events-none absolute inset-0 -z-10">
        <div class="absolute left-1/2 top-1/3 h-[42rem] w-[42rem] -translate-x-1/2 rounded-full bg-red/10 blur-[120px]"></div>
      </div>

      <div class="mx-auto w-full max-w-3xl px-5 text-center md:px-8">
        <p class="inline-flex items-center justify-center gap-2 text-xs font-semibold uppercase tracking-[0.28em] text-tan">
          <span class="h-px w-6 bg-tan/60"></span>
          Your Photos
          <span class="h-px w-6 bg-tan/60"></span>
        </p>

        <h1 class="mt-4 font-display text-4xl font-bold leading-[1.15] text-bone sm:text-5xl">
          {galleryUrl ? 'Your photos are waiting.' : 'We caught your winning moment.'}
        </h1>
        {
          galleryUrl ? (
            <p class="mx-auto mt-5 max-w-lg text-lg leading-relaxed text-bone-dim">
              Taking you to the gallery — browse your shots and order prints or digital downloads.
              If nothing happens, tap the button below.
            </p>
          ) : (
            <>
              <p class="mx-auto mt-5 max-w-lg text-lg leading-relaxed text-bone-dim">
                Photos from today's shoot are being edited right now. The full gallery — with prints
                and digital downloads for sale — goes live within 48 hours.
              </p>
              <p class="mx-auto mt-3 max-w-lg text-lg leading-relaxed text-bone-dim">
                Want the link the moment it drops? Send us your name and number and we'll text it to
                you.
              </p>
            </>
          )
        }

        <div class="mt-9 flex flex-wrap items-center justify-center gap-4">
          <a
            href={galleryUrl || `sms:${phoneHref}`}
            class="group inline-flex items-center justify-center gap-2 rounded-full bg-red px-7 py-3.5 text-base font-semibold text-bone shadow-lg shadow-red/20 transition-all duration-200 hover:bg-red-bright hover:shadow-red/30"
          >
            {galleryUrl ? 'Open the Gallery' : 'Text Us Your Name'}
            <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
          <a
            href="/#contact"
            class="inline-flex items-center justify-center gap-2 rounded-full border border-tan/40 px-7 py-3.5 text-base font-semibold text-tan transition-all duration-200 hover:border-tan hover:bg-tan hover:text-ink"
          >
            Or Email Us
          </a>
        </div>

        <div class="mx-auto mt-12 max-w-md space-y-2 border-t border-ink-line pt-8 text-sm text-bone-faint">
          <p>
            Call or text: <a href={`tel:${phoneHref}`} class="text-tan underline-offset-4 hover:underline">{phone}</a>
          </p>
          <p>
            Email: <a href={`mailto:${email}`} class="text-tan underline-offset-4 hover:underline">{email}</a>
          </p>
          {
            instagram && (
              <p>
                Sneak peeks land on{' '}
                <a href={instagram.href} target="_blank" rel="noopener" class="text-tan underline-offset-4 hover:underline">
                  Instagram {instagram.handle}
                </a>
              </p>
            )
          }
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
