---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page not found — Lone Hand Media">
  <Nav />
  <main>
    <section class="felt relative flex min-h-[100svh] items-center overflow-hidden pt-28 pb-16">
      <div class="pointer-events-none absolute inset-0 -z-10">
        <div class="absolute left-1/2 top-1/3 h-[42rem] w-[42rem] -translate-x-1/2 rounded-full bg-red/10 blur-[120px]"></div>
      </div>

      <div class="mx-auto w-full max-w-3xl px-5 text-center md:px-8">
        <!-- Dead man's hand: a lone joker -->
        <div class="mx-auto mb-10 h-52 w-36 rotate-6 select-none rounded-2xl border border-tan/60 bg-gradient-to-b from-[#17171c] to-[#0b0b0d] p-2 shadow-2xl shadow-black/70 ring-1 ring-inset ring-tan/10" aria-hidden="true">
          <div class="flex h-full w-full flex-col justify-between rounded-xl border border-tan/35 p-3">
            <span class="font-display text-2xl font-semibold leading-none text-tan">?</span>
            <span class="self-center font-display text-5xl text-red-bright drop-shadow-[0_2px_14px_rgba(226,21,42,0.45)]">404</span>
            <span class="rotate-180 self-start font-display text-2xl font-semibold leading-none text-tan">?</span>
          </div>
        </div>

        <h1 class="font-display text-4xl font-bold text-bone sm:text-5xl">This card isn't in the deck.</h1>
        <p class="mx-auto mt-5 max-w-md text-lg leading-relaxed text-bone-dim">
          The page you're looking for was folded, shuffled away, or never dealt. Let's get you back to the table.
        </p>

        <a
          href="/"
          class="group mt-9 inline-flex items-center justify-center gap-2 rounded-full bg-red px-7 py-3.5 text-base font-semibold text-bone shadow-lg shadow-red/20 transition-all duration-200 hover:bg-red-bright hover:shadow-red/30"
        >
          Back to the table
          <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" viewBox="0 0 16 16" fill="none">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
