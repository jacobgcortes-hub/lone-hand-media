---
import Section from './Section.astro';
import data from '../data/process.json';
const steps = data.steps;
---

<section id="process" class="relative overflow-hidden border-y border-ink-line bg-ink-soft py-24 md:py-32">
  <div class="felt pointer-events-none absolute inset-0 opacity-70"></div>
  <div class="relative mx-auto max-w-7xl px-5 md:px-8">
    <Section eyebrow={data.eyebrow} title={data.title} intro={data.intro} />

    <div class="mt-16 grid gap-px overflow-hidden rounded-3xl border border-ink-line bg-ink-line sm:grid-cols-2 lg:grid-cols-4">
      {
        steps.map((s, i) => (
          <div
            class="group relative bg-ink p-8 transition-colors duration-300 hover:bg-ink-card"
            data-reveal
            style={`--reveal-delay:${i * 120}ms`}
          >
            <span class="font-sans text-5xl font-bold tracking-tight text-ink-line transition-colors duration-300 group-hover:text-red/70">
              {s.n}
            </span>
            <h3 class="mt-5 font-display text-xl font-semibold text-bone">{s.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-bone-dim">{s.copy}</p>
            <span class="mt-6 block h-px w-10 bg-tan/50 transition-all duration-300 group-hover:w-16"></span>
          </div>
        ))
      }
    </div>
  </div>
</section>
