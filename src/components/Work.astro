---
import Section from './Section.astro';
import data from '../data/work.json';

// Gradients stand in until a real image is set on a project (via the CMS).
const filters = ['All', 'Photo', 'Video', 'Social'];
const projects = data.items;
const hasWork = projects.length > 0;
---

<section id="work" class="relative py-24 md:py-32">
  <div class="mx-auto max-w-7xl px-5 md:px-8">
    {
      hasWork ? (
        <>
          <div class="flex flex-col items-start justify-between gap-8 md:flex-row md:items-end">
            <Section align="left" eyebrow={data.eyebrow} title={data.title} intro={data.intro} />

            <div class="flex flex-wrap gap-2" data-reveal style="--reveal-delay:200ms">
              {filters.map((f, i) => (
                <button
                  class={`work-filter cursor-pointer rounded-full border px-4 py-2 text-sm font-medium transition-colors duration-200 ${
                    i === 0
                      ? 'border-tan bg-tan text-ink'
                      : 'border-ink-line text-bone-dim hover:border-tan/50 hover:text-bone'
                  }`}
                  data-filter={f}
                  aria-pressed={i === 0 ? 'true' : 'false'}
                >
                  {f}
                </button>
              ))}
            </div>
          </div>

          <div class="mt-12 grid auto-rows-[13rem] grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-4">
            {projects.map((p, i) => (
              <article
                class={`work-item group relative overflow-hidden rounded-2xl border border-ink-line bg-gradient-to-br ${p.bg} ${p.span} ${p.video ? 'cursor-pointer' : ''}`}
                data-cat={p.cat}
                data-video={p.video || undefined}
                role={p.video ? 'button' : undefined}
                tabindex={p.video ? 0 : undefined}
                aria-label={p.video ? `Play video: ${p.title}` : undefined}
                data-reveal
                style={`--reveal-delay:${i * 80}ms`}
              >
                {p.image && (
                  <img
                    src={p.image}
                    alt={p.title}
                    loading="lazy"
                    decoding="async"
                    class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                )}
                <div class="absolute inset-0 felt opacity-60" />
                {p.kind === 'reel' && (
                  <span class="absolute right-4 top-4 inline-flex h-9 w-9 items-center justify-center rounded-full border border-bone/30 bg-ink/40 text-bone backdrop-blur transition-transform duration-300 group-hover:scale-110">
                    <svg class="h-3.5 w-3.5 translate-x-px" viewBox="0 0 16 16" fill="currentColor">
                      <path d="M4 2.5v11l9-5.5z" />
                    </svg>
                  </span>
                )}
                <div class="absolute inset-x-0 bottom-0 translate-y-2 p-5 opacity-0 transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">
                  <span class="text-[0.65rem] font-semibold uppercase tracking-[0.2em] text-tan">{p.tag}</span>
                  <h3 class="mt-1 font-display text-lg font-semibold leading-snug text-bone">{p.title}</h3>
                </div>
                <div class="absolute inset-0 ring-0 ring-tan/0 transition-all duration-300 group-hover:ring-1 group-hover:ring-tan/40" />
              </article>
            ))}
          </div>
        </>
      ) : (
        <div class="mx-auto max-w-2xl text-center">
          <p
            class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.28em] text-tan"
            data-reveal
          >
            <span class="h-px w-6 bg-tan/60" />
            Selected Work
          </p>
          <h2
            class="mt-4 font-display text-4xl font-bold leading-[1.15] text-bone sm:text-5xl md:text-[3.25rem]"
            data-reveal
            style="--reveal-delay:90ms"
          >
            Fresh hands, coming soon.
          </h2>
          <p
            class="mt-5 text-lg leading-relaxed text-bone-dim"
            data-reveal
            style="--reveal-delay:180ms"
          >
            New photo and video work is being shot right now. Check back shortly — the deck is
            about to get a whole lot more interesting.
          </p>

          <div class="mt-12 flex justify-center gap-3" data-reveal style="--reveal-delay:260ms">
            {['♠', '♥', '♣', '♦'].map((s, i) => (
              <span
                class={`floaty grid h-16 w-12 place-content-center rounded-xl border border-tan/25 bg-gradient-to-b from-ink-card to-ink text-2xl shadow-xl shadow-black/50 ${
                  i === 1 || i === 3 ? 'text-red-bright' : 'text-bone'
                }`}
                style={`--rot:0deg; --float-delay:${i * 600}ms`}
              >
                {s}
              </span>
            ))}
          </div>
        </div>
      )
    }
  </div>

  <!-- Lightbox for video tiles -->
  <div
    id="video-modal"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-ink/90 p-4 backdrop-blur-sm md:p-10"
    aria-modal="true"
    role="dialog"
  >
    <button
      id="video-close"
      class="absolute right-5 top-5 grid h-11 w-11 cursor-pointer place-content-center rounded-full border border-bone/30 text-bone transition-colors hover:border-tan hover:text-tan"
      aria-label="Close video"
    >
      <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none">
        <path d="M3 3l10 10M13 3L3 13" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />
      </svg>
    </button>
    <div class="aspect-video w-full max-w-5xl overflow-hidden rounded-2xl border border-ink-line bg-ink shadow-2xl shadow-black/60">
      <iframe
        id="video-frame"
        class="h-full w-full"
        src=""
        title="Lone Hand Media video"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
  </div>
</section>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.work-filter');
  const items = document.querySelectorAll<HTMLElement>('.work-item');

  // --- Video lightbox -------------------------------------------------
  const modal = document.getElementById('video-modal');
  const frame = document.getElementById('video-frame') as HTMLIFrameElement | null;

  const youtubeId = (url: string) =>
    url.match(/(?:youtu\.be\/|[?&]v=|\/embed\/|\/shorts\/)([\w-]{11})/)?.[1] ?? null;

  const openVideo = (url: string) => {
    const id = youtubeId(url);
    if (!id || !modal || !frame) return;
    frame.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
  };

  const closeVideo = () => {
    if (!modal || !frame) return;
    frame.src = '';
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
  };

  items.forEach((item) => {
    const url = item.dataset.video;
    if (!url) return;
    item.addEventListener('click', () => openVideo(url));
    item.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        openVideo(url);
      }
    });
  });

  document.getElementById('video-close')?.addEventListener('click', closeVideo);
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeVideo();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeVideo();
  });

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;

      buttons.forEach((b) => {
        const active = b === btn;
        b.setAttribute('aria-pressed', String(active));
        b.classList.toggle('bg-tan', active);
        b.classList.toggle('text-ink', active);
        b.classList.toggle('border-tan', active);
        b.classList.toggle('text-bone-dim', !active);
        b.classList.toggle('border-ink-line', !active);
      });

      items.forEach((item) => {
        const show = filter === 'All' || item.dataset.cat === filter;
        item.style.display = show ? '' : 'none';
      });
    });
  });
</script>
