---
import Section from './Section.astro';
import data from '../data/testimonials.json';
const quotes = data.items;
---

{
  quotes.length > 0 && (
    <section id="testimonials" class="relative py-24 md:py-32">
      <div class="mx-auto max-w-7xl px-5 md:px-8">
        <Section eyebrow={data.eyebrow} title={data.title} />

        <div class="mt-16 grid gap-6 md:grid-cols-3">
          {quotes.map((q, i) => (
            <figure
              class="relative flex flex-col rounded-3xl border border-ink-line bg-ink-card p-8 transition-all duration-300 hover:-translate-y-1 hover:border-tan/30"
              data-reveal
              style={`--reveal-delay:${i * 120}ms`}
            >
              <div class="mb-5 flex items-center gap-1 text-tan">
                {Array.from({ length: 5 }).map(() => (
                  <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M10 1.5l2.6 5.3 5.9.9-4.3 4.1 1 5.8L10 14.9 4.8 17.6l1-5.8L1.5 7.7l5.9-.9z" />
                  </svg>
                ))}
              </div>
              <blockquote class="flex-1 text-lg leading-relaxed text-bone">“{q.quote}”</blockquote>
              <figcaption class="mt-7 flex items-center gap-4 border-t border-ink-line pt-5">
                <span class={`grid h-11 w-11 place-content-center rounded-full border text-xl ${i === 1 || i === 2 ? 'border-red/30 bg-red/10 text-red-bright' : 'border-tan/30 bg-tan/10 text-bone'}`}>
                  {q.suit}
                </span>
                <span>
                  <span class="block text-sm font-semibold text-bone">{q.name}</span>
                  <span class="block text-xs text-bone-faint">{q.role}</span>
                </span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>
  )
}
