---
import Section from './Section.astro';
import site from '../data/site.json';

// Icon paths live in code, keyed by platform; handles/links come from the CMS.
const icons: Record<string, string> = {
  Instagram: 'M12 2.2c3.2 0 3.6 0 4.9.07 1.2.05 1.8.25 2.2.42.6.2 1 .5 1.4.9.4.4.7.8.9 1.4.17.4.37 1 .42 2.2.06 1.3.07 1.7.07 4.9s0 3.6-.07 4.9c-.05 1.2-.25 1.8-.42 2.2-.2.6-.5 1-.9 1.4-.4.4-.8.7-1.4.9-.4.17-1 .37-2.2.42-1.3.06-1.7.07-4.9.07s-3.6 0-4.9-.07c-1.2-.05-1.8-.25-2.2-.42-.6-.2-1-.5-1.4-.9-.4-.4-.7-.8-.9-1.4-.17-.4-.37-1-.42-2.2C2.2 15.6 2.2 15.2 2.2 12s0-3.6.07-4.9c.05-1.2.25-1.8.42-2.2.2-.6.5-1 .9-1.4.4-.4.8-.7 1.4-.9.4-.17 1-.37 2.2-.42C8.4 2.2 8.8 2.2 12 2.2Zm0 3.3a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13Zm0 10.7a4.2 4.2 0 1 1 0-8.4 4.2 4.2 0 0 1 0 8.4Zm6.7-10.9a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z',
  TikTok: 'M16.6 5.8a4.8 4.8 0 0 1-2.9-1.7v8.9a5.6 5.6 0 1 1-5.6-5.6c.3 0 .6 0 .9.07v2.8a2.8 2.8 0 1 0 2 2.7V2h2.7a4.8 4.8 0 0 0 2.9 4.4v-.6Z',
  YouTube: 'M21.6 7.2a2.5 2.5 0 0 0-1.8-1.8C18.3 5 12 5 12 5s-6.3 0-7.8.4A2.5 2.5 0 0 0 2.4 7.2 26 26 0 0 0 2 12a26 26 0 0 0 .4 4.8 2.5 2.5 0 0 0 1.8 1.8C5.7 19 12 19 12 19s6.3 0 7.8-.4a2.5 2.5 0 0 0 1.8-1.8A26 26 0 0 0 22 12a26 26 0 0 0-.4-4.8ZM10 14.8V9.2l4.8 2.8-4.8 2.8Z',
};
const socials = site.social.map((s) => ({
  name: s.platform,
  handle: s.handle,
  href: s.href,
  icon: icons[s.platform] ?? icons.Instagram,
}));
---

<section id="social" class="relative py-24 md:py-32">
  <div class="mx-auto max-w-5xl px-5 md:px-8">
    <div class="relative overflow-hidden rounded-[2rem] border border-ink-line bg-gradient-to-b from-ink-card to-ink-soft p-10 text-center md:p-16">
      <div class="felt pointer-events-none absolute inset-0 opacity-80"></div>
      <div class="pointer-events-none absolute -left-10 -top-10 font-display text-[12rem] leading-none text-red/5">♠</div>
      <div class="pointer-events-none absolute -bottom-16 -right-6 font-display text-[12rem] leading-none text-tan/5">♥</div>

      <div class="relative">
        <Section
          eyebrow="Follow the Play"
          title="See what we’re dealing daily."
          intro="New work, behind-the-scenes and growth tips land on our channels every week. Pull up a seat."
        />

        <div class="mt-12 flex flex-col items-center justify-center gap-4 sm:flex-row" data-reveal>
          {
            socials.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex w-full items-center gap-4 rounded-2xl border border-ink-line bg-ink/60 px-5 py-4 text-left transition-all duration-200 hover:-translate-y-0.5 hover:border-tan/40 sm:w-auto"
              >
                <span class="grid h-11 w-11 shrink-0 place-content-center rounded-xl bg-ink-card text-bone transition-colors duration-200 group-hover:bg-red group-hover:text-bone">
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d={s.icon} />
                  </svg>
                </span>
                <span>
                  <span class="block text-sm font-semibold text-bone">{s.name}</span>
                  <span class="block text-xs text-bone-faint">{s.handle}</span>
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
