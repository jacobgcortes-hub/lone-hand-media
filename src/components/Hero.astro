---
import site from '../data/site.json';
const { hero } = site;

// The winning hand: a Royal Flush in hearts that deals in on load.
const suit = '♥';
const hand = [
  { rank: '10', rot: -16, dx: '-60%', dr: '-22deg', delay: 120 },
  { rank: 'J', rot: -8, dx: '-30%', dr: '-12deg', delay: 240 },
  { rank: 'Q', rot: 0, dx: '0%', dr: '0deg', delay: 360 },
  { rank: 'K', rot: 8, dx: '30%', dr: '12deg', delay: 480 },
  { rank: 'A', rot: 16, dx: '60%', dr: '22deg', delay: 600 },
];
---

<section id="top" class="felt relative flex min-h-[100svh] items-center overflow-hidden pt-28 pb-16">
  <!-- backdrop glow -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute left-1/2 top-1/3 h-[42rem] w-[42rem] -translate-x-1/2 rounded-full bg-red/10 blur-[120px]"></div>
    <div class="absolute bottom-0 right-0 h-[28rem] w-[28rem] rounded-full bg-tan/5 blur-[100px]"></div>
  </div>

  <div class="mx-auto grid w-full max-w-7xl items-center gap-12 px-5 md:px-8 lg:grid-cols-[1.05fr_0.95fr]">
    <!-- Copy -->
    <div class="text-center lg:text-left">
      <p
        class="mb-7 inline-flex items-center gap-3 text-[0.7rem] font-semibold uppercase tracking-[0.5em] text-tan"
        data-reveal
      >
        <span class="h-px w-9 bg-tan/55"></span>
        {hero.eyebrow}
      </p>

      <h1 class="font-display font-bold leading-[1.05]">
        <span class="block text-4xl sm:text-6xl lg:text-7xl" data-reveal style="--reveal-delay:80ms">{hero.headlineTop}</span>
        <span class="shimmer-text font-script block pb-1 text-6xl leading-[1.15] sm:text-8xl lg:text-[6.75rem]" data-reveal style="--reveal-delay:200ms">{hero.headlineAccent}</span>
      </h1>

      <p
        class="mx-auto mt-7 max-w-xl text-lg leading-relaxed text-bone-dim lg:mx-0"
        data-reveal
        style="--reveal-delay:320ms"
      >
        {hero.subhead}
      </p>

      <div
        class="mt-9 flex flex-col items-center gap-3 sm:flex-row lg:justify-start"
        data-reveal
        style="--reveal-delay:440ms"
      >
        <a
          href="#contact"
          class="group inline-flex w-full items-center justify-center gap-2 rounded-full bg-red px-7 py-3.5 text-base font-semibold text-bone shadow-lg shadow-red/20 transition-all duration-200 hover:bg-red-bright hover:shadow-red/30 sm:w-auto"
        >
          {hero.primaryCta}
          <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" viewBox="0 0 16 16" fill="none">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
        <a
          href="#work"
          class="inline-flex w-full items-center justify-center gap-2 rounded-full border border-ink-line px-7 py-3.5 text-base font-semibold text-bone transition-colors duration-200 hover:border-tan hover:text-tan sm:w-auto"
        >
          {hero.secondaryCta}
        </a>
      </div>

      <!-- Stat strip -->
      {hero.stats.length > 0 && (
      <dl
        class="mt-12 grid max-w-lg grid-cols-3 gap-6 border-t border-ink-line pt-7 text-center lg:mx-0 lg:text-left"
        data-reveal
        style="--reveal-delay:560ms"
      >
        {
          hero.stats.map((s) => (
            <div>
              <dt class="font-sans text-3xl font-bold tracking-tight text-bone">{s.n}</dt>
              <dd class="mt-1 text-xs uppercase tracking-wider text-bone-faint">{s.l}</dd>
            </div>
          ))
        }
      </dl>
      )}
    </div>

    <!-- Fanned hand of cards -->
    <div class="relative mx-auto hidden h-[26rem] w-full max-w-md select-none lg:block" aria-hidden="true">
      <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
        {
          hand.map((c, i) => (
            <div
              class="deal-card floaty absolute left-1/2 top-1/2 h-56 w-40 -translate-x-1/2 -translate-y-1/2 rounded-2xl border border-tan/60 bg-gradient-to-b from-[#17171c] to-[#0b0b0d] p-2 shadow-2xl shadow-black/70 ring-1 ring-inset ring-tan/10"
              style={`--rot:${c.rot}deg; --dx:${c.dx}; --dr:${c.dr}; --delay:${c.delay}ms; --float-delay:${i * 700}ms; transform-origin:center bottom; margin-left:${(i - 2) * 38}px; z-index:${10 + i};`}
            >
              {/* inset gold frame */}
              <div class="flex h-full w-full flex-col justify-between rounded-xl border border-tan/35 p-3">
                <span class="font-display text-2xl font-semibold leading-none text-tan">
                  {c.rank}
                  <span class="mt-0.5 block text-sm leading-none text-red-bright">{suit}</span>
                </span>
                <span class="self-center text-[3.25rem] text-red-bright drop-shadow-[0_2px_14px_rgba(226,21,42,0.45)]">{suit}</span>
                <span class="rotate-180 self-start font-display text-2xl font-semibold leading-none text-tan">
                  {c.rank}
                  <span class="mt-0.5 block text-sm leading-none text-red-bright">{suit}</span>
                </span>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <!-- scroll cue -->
  <a
    href="#work"
    class="absolute bottom-6 left-1/2 hidden -translate-x-1/2 flex-col items-center gap-2 text-bone-faint transition-colors hover:text-tan md:flex"
    aria-label="Scroll to work"
  >
    <span class="text-[0.65rem] uppercase tracking-[0.3em]">Scroll</span>
    <span class="h-9 w-px animate-pulse bg-gradient-to-b from-tan to-transparent"></span>
  </a>
</section>
