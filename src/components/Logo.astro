---
/**
 * Lone Hand Media logo — signature-script wordmark.
 * (Wordmark only: "Lone Hand" in script + "Media" in letterspaced serif.)
 */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<span class={`inline-flex flex-col leading-none ${className}`} aria-label="Lone Hand Media">
  <span class="font-script text-[2rem] leading-[0.7] text-bone">Lone Hand</span>
  <span class="mt-0.5 self-center font-display text-[0.62rem] font-semibold uppercase tracking-[0.5em] text-tan" style="padding-left:0.5em">Media</span>
</span>
