---
import Section from './Section.astro';
import data from '../data/services.json';
const services = data.items;
---

<section id="services" class="relative py-24 md:py-32">
  <div class="mx-auto max-w-7xl px-5 md:px-8">
    <Section eyebrow={data.eyebrow} title={data.title} intro={data.intro} />

    <div class="mt-16 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        services.map((s, i) => (
          <article
            class="group relative overflow-hidden rounded-3xl border border-ink-line bg-ink-card p-7 transition-all duration-300 hover:-translate-y-1 hover:border-tan/40 hover:shadow-2xl hover:shadow-black/50"
            data-reveal
            style={`--reveal-delay:${i * 110}ms`}
          >
            <div class="pointer-events-none absolute -right-6 -top-8 font-display text-[7rem] leading-none text-ink-line transition-colors duration-300 group-hover:text-tan/15">
              {s.suit}
            </div>

            <span
              class={`relative inline-flex h-12 w-12 items-center justify-center rounded-xl border text-2xl ${
                s.tone === 'red'
                  ? 'border-red/30 bg-red/10 text-red-bright'
                  : 'border-tan/30 bg-tan/10 text-bone'
              }`}
            >
              {s.suit}
            </span>

            <h3 class="relative mt-6 font-display text-xl font-semibold text-bone">{s.title}</h3>
            <p class="relative mt-3 text-sm leading-relaxed text-bone-dim">{s.copy}</p>

            <ul class="relative mt-5 space-y-2 border-t border-ink-line pt-5">
              {s.points.map((p) => (
                <li class="flex items-center gap-2 text-sm text-bone-dim">
                  <svg class="h-3.5 w-3.5 shrink-0 text-tan" viewBox="0 0 16 16" fill="none">
                    <path d="M3 8.5l3 3 7-7.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                  {p}
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
